generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scenes    Scene[]

  // Phase 2 additions
  characterRefUrls    String[]            @default([])   // fal storage URLs, up to 3
  characterReelUrl    String?                             // Wan 2.6 R2V output video URL
  characterReelStatus CharacterReelStatus @default(NONE)
  wanRequestId        String?                             // in-flight Wan job request_id

  // Phase 3 additions
  voiceSampleUrl      String?                             // fal storage URL of uploaded audio clip
  klingVoiceId        String?                             // Kling voice ID created from voiceSampleUrl
  voiceStatus         VoiceStatus         @default(NONE)
}

enum CharacterReelStatus {
  NONE       // no refs uploaded yet
  PENDING    // refs uploaded, reel not yet generated
  GENERATING // Wan R2V job in flight
  COMPLETE   // reel ready, Kling will use it
  FAILED     // Wan job failed — scenes generate without reel
}

model Scene {
  id                String      @id @default(cuid())
  projectId         String
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  motionPrompt      String
  sketchDataUrl     String?     @db.Text
  referenceImageUrl String?
  uprenderUrl       String?
  videoUrl          String?
  status            SceneStatus @default(PENDING)
  dialogue          String?     // Phase 3: character dialogue lines for this scene
  inngestRunId      String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([projectId])
}

enum SceneStatus {
  PENDING
  UPLOADING
  UPRENDERING
  GENERATING_VIDEO
  COMPLETE
  FAILED
}

enum VoiceStatus {
  NONE      // no voice sample uploaded
  PENDING   // sample uploaded, voice ID not yet created
  CREATING  // Kling voice ID creation in flight
  READY     // voice ID ready, all scenes will use it
  FAILED    // voice ID creation failed — scenes generate without voice
}
